{
  "name": "626labs-themes",
  "displayName": "626 Labs Themes",
  "description": "The 626 Labs theme family — neon-duotone dark, cyan and magenta on deep navy. Two variants: Night (deeper) and Storm (lighter). Structurally inspired by Tokyo Night.",
  "version": "0.1.0",
  "publisher": "626LabsLLC",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "dark",
    "626labs",
    "neon",
    "tokyo night",
    "vibe coding"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#0a1524",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/estevanhernandez-stack-ed/626labs-themes.git"
  },
  "homepage": "https://626labs.dev",
  "bugs": {
    "url": "https://github.com/estevanhernandez-stack-ed/626labs-themes/issues"
  },
  "contributes": {
    "themes": [
      {
        "label": "626 Labs Night",
        "uiTheme": "vs-dark",
        "path": "./themes/626labs-night-color-theme.json"
      },
      {
        "label": "626 Labs Storm",
        "uiTheme": "vs-dark",
        "path": "./themes/626labs-storm-color-theme.json"
      }
    ]
  },
  "scripts": {
    "build:storm": "node scripts/build-storm.js",
    "package": "vsce package",
    "publish": "vsce publish"
  }
}
